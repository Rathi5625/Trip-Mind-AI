# =========================================================================
# TRIP MIND AI - ENVIRONMENT CONFIGURATION (TEMPLATE)
# Copy this file to '.env' (do NOT commit .env to GitHub)
# =========================================================================

# Database Configuration
SPRING_DATASOURCE_HOST=localhost
SPRING_DATASOURCE_PORT=5432
SPRING_DATASOURCE_DB=tripmind_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_postgres_password_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# NVIDIA AI API Key (Nemotron Ultra / Llama models)
# Get a key from: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# NVIDIA Image API Key (Nemotron Nano / FLUX.1-schnell via NVIDIA API Catalog)
NVIDIA_IMAGE_API_KEY=your_nvidia_image_api_key_here

# Unsplash API Key (destination photos)
# Sign up at: https://unsplash.com/developers → Create App → copy Access Key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Tavily API Key (real-time web research for AI Copilot)
# Sign up at: https://tavily.com → copy API key (starts with tvly-...)
TAVILY_API_KEY=your_tavily_api_key_here

# Weather Provider API
WEATHER_API_KEY=your_weather_api_key_here

# Gmail SMTP Credentials
# For Gmail, you MUST generate an App Password: https://support.google.com/accounts/answer/185833
SPRING_MAIL_USERNAME=your_gmail_username@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password_here

