# =========================================================================
# TRIP MIND AI - BACKEND ENVIRONMENT TEMPLATE (.env.example)
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the real .env file to Git!
# =========================================================================

# Database Credentials
SPRING_DATASOURCE_HOST=localhost
SPRING_DATASOURCE_PORT=5432
SPRING_DATASOURCE_DB=tripmind_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# JWT Security Configuration
# Generate a strong 256-bit secret key (Base64 encoded or 64 hex characters)
JWT_SECRET=your_jwt_secret_key_here_min_256_bits
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Google Gemini API Key (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Weather API Key (https://www.weatherapi.com/)
WEATHER_API_KEY=your_weather_api_key_here

# NVIDIA AI API Key (https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_IMAGE_API_KEY=your_nvidia_image_api_key_here

# Unsplash API Access Key (https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Tavily Web Search API Key (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Gmail SMTP Credentials for OTP & Email Notifications
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_gmail_app_password_here

# Server & CORS Configurations
PORT=8080
FRONTEND_URL=http://localhost:3000
